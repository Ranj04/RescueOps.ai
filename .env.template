# EdgeOne Makers OpenAI-compatible model gateway
LLM_BASE_URL=https://ai-gateway.edgeone.link/v1
MAKERS_MODELS_KEY=
LLM_PRIMARY_MODEL=@makers/deepseek-v4-flash
LLM_FALLBACK_MODEL=@makers/minimax-m2.7
ANTHROPIC_API_KEY=

# --- Legacy TrueFoundry config.py path (prior prototype, not target architecture) ---
# TrueFoundry AI Gateway base URL (ends with /api/llm)
TFY_GATEWAY_BASE_URL=https://<your-gateway>.truefoundry.cloud/api/llm

# TrueFoundry gateway API key
TFY_API_KEY=<your-api-key>

# Model IDs as configured/aliased in the TrueFoundry gateway (NOT raw vendor IDs).
# Grok is the primary; Claude and Gemini are fallbacks.
GROK_MODEL_ID=<grok-model-id-as-configured-in-gateway>
CLAUDE_MODEL_ID=<claude-model-id-as-configured-in-gateway>
GEMINI_MODEL_ID=<gemini-model-id-as-configured-in-gateway>

# Optional — B5 voice approval (best-effort; falls back to macOS `say`).
# Used by voice.py for Grok TTS directly against the xAI API (not the gateway).
# XAI_API_KEY=<your-xai-api-key>
# XAI_TTS_MODEL=grok-tts
# XAI_TTS_VOICE=alloy
