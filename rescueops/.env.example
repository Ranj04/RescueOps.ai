# TrueFoundry AI Gateway — required for CrewAI cloud deploy and local `crewai run`.
# Copy to .env and fill in values from your TrueFoundry tenant (Gateway → Code snippet).

TFY_GATEWAY_BASE_URL=https://gateway.truefoundry.ai/api/llm
TFY_API_KEY=<your-gateway-api-key>

GROK_MODEL_ID=xai/grok-3
CLAUDE_MODEL_ID=anthropic/claude-sonnet-4-5
GEMINI_MODEL_ID=google-gemini/gemini-2.5-flash-lite

# Optional — direct Anthropic fallback when gateway vars are unset (local dev only)
# ANTHROPIC_API_KEY=<your-anthropic-key>
